---
// Vector Field with Sobel Operator Visualization
const { title = 'Vector Field - Sobel Operator' } = Astro.props;
---

<div class="p5-component">
  <div id="vf_sobel_canva"></div>
</div>

<script>
  import vectorfield_sobel_visual_sketch from '../../../scripts/vectorfield_sobel_visual.js';

  // Initialize p5 instance with the sketch
  const initVectorfieldSobelVisual = () => {
    if (typeof window !== 'undefined' && window.p5) {
      new p5((p) => vectorfield_sobel_visual_sketch(p, 'vf_sobel_canva'));
    }
  };

  // Wait for p5 to be loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initVectorfieldSobelVisual);
  } else {
    initVectorfieldSobelVisual();
  }
</script>

<style>
  .p5-component {
    margin: 2rem 0;
    display: flex;
    justify-content: center;
  }

  #vf_sobel_canva {
    border: 2px solid #dee2e6;
    border-radius: 4px;
    overflow: hidden;
    background: white;
  }
</style>
