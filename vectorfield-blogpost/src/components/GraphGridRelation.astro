---
// Graph Grid Relation Visualization
const { title = "Graph Grid Relation" } = Astro.props;
---

<div class="p5-component">
  <div id="graph_grid_relation_canva"></div>
</div>

<script>
  import graph_grid_relation_sketch from '../../../scripts/graph_grid_relation.js';

  // Initialize p5 instance with the sketch
  const initGraphGridRelation = () => {
    if (typeof window !== 'undefined' && window.p5) {
      new p5((p) => graph_grid_relation_sketch(p, 'graph_grid_relation_canva'));
    }
  };

  // Wait for p5 to be loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGraphGridRelation);
  } else {
    initGraphGridRelation();
  }
</script>

<style>
  .p5-component {
    margin: 2rem 0;
    display: flex;
    justify-content: center;
  }

  #graph_grid_relation_canva {
    border: 2px solid #dee2e6;
    border-radius: 4px;
    overflow: hidden;
    background: white;
  }
</style>
