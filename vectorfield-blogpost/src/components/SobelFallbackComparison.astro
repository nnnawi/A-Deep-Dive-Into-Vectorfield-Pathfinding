---
// Sobel Fallback Comparison Visualization
const { title = 'Sobel Fallback Comparison' } = Astro.props;
---

<div class="p5-component">
  <div id="sobel_fallback_comparison_canva"></div>
</div>

<script>
  import sobel_fallback_comparison_sketch from '../../../scripts/sobel_fallback_comparison.js';

  // Initialize p5 instance with the sketch
  const initSobelFallbackComparison = () => {
    if (typeof window !== 'undefined' && window.p5) {
      new p5((p) =>
        sobel_fallback_comparison_sketch(p, 'sobel_fallback_comparison_canva')
      );
    }
  };

  // Wait for p5 to be loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSobelFallbackComparison);
  } else {
    initSobelFallbackComparison();
  }
</script>

<style>
  .p5-component {
    margin: 2rem 0;
    display: flex;
    justify-content: center;
  }

  #sobel_fallback_comparison_canva {
    border: 2px solid #dee2e6;
    border-radius: 4px;
    overflow: hidden;
    background: white;
  }
</style>
