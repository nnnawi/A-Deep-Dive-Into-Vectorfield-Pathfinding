---
// Distance Kernel Comparison Visualization
---

<div id="distanceKernelComparison"></div>


<script>
import { dist_arr } from '../common/constant';
import { djikstra_algorithm, node } from '../common/solver_function';
import { setupVisibilityPause } from '../common/p5_utils';

  const sketch = (p) => {
     const arg = {
        screen: {
            w: 900,
            h: 350,
        },
        grid: {
            tile_size: 26,
            w: 9,
            h: 9,
            stroke: 100,
            stroke_weight: 1,
        },
        layout: {
            grid_width: 234,  // 9 * 26
            grid_height: 234,
            gap: 50,
            start_x: 0,
            title_height: 40,
            controls_height: 60,
        }
    }

    // Graphics layers for each grid
    var gfx_heatmaps = [];

    // Three separate node grids
    var node_grids = [];

    // Target at the center
    var target = {
        x: 4,
        y: 4,
    }

    // Color palette mode
    var colorMode = 'hue'; // 'hue' or 'grayscale'

    // Calculate grid positions
    arg.layout.start_x = (arg.screen.w - (arg.layout.grid_width * 3 + arg.layout.gap * 2)) / 2;

    function getGridX(gridIndex) {
        return arg.layout.start_x + gridIndex * (arg.layout.grid_width + arg.layout.gap);
    }

    p.setup = () => {
        let canvas = p.createCanvas(arg.screen.w, arg.screen.h);
        canvas.parent("distanceKernelComparison");

        // Create three node grids
        const kernelNames = Object.keys(dist_arr);
        for (let i = 0; i < 3; i++) {
            let node_grid = new Array(arg.grid.h).fill().map((_, y) =>
                new Array(arg.grid.w).fill().map((_, x) => new node(x, y))
            );
            node_grids.push(node_grid);

            // Create graphics for heatmap
            gfx_heatmaps.push(p.createGraphics(arg.grid.w * arg.grid.tile_size, arg.grid.h * arg.grid.tile_size));

            // Compute Dijkstra with the corresponding kernel
            djikstra_algorithm(node_grid, target, dist_arr[kernelNames[i]], arg);
        }

        // Setup event listeners for radio buttons
        const radioButtons = document.querySelectorAll('input[name="distance_kernel_color_palette"]');
        radioButtons.forEach(radio => {
            radio.addEventListener('change', (e) => {
                colorMode = e.target.value;
            });
        });
    }

    p.draw = () => {
        // p.background(0);

        // Update display values for all grids
        for (let gridIndex = 0; gridIndex < 3; gridIndex++) {
            for (let y = 0; y < arg.grid.h; y++) {
                for (let x = 0; x < arg.grid.w; x++) {
                    let current_node = node_grids[gridIndex][y][x];
                    current_node.update_display_dist(p, 0.05);
                }
            }
        }

        // Draw each grid
        for (let gridIndex = 0; gridIndex < 3; gridIndex++) {
            let gridX = getGridX(gridIndex);

            // Draw heatmap
            gfx_draw_heatmap_local(p, gfx_heatmaps[gridIndex], node_grids[gridIndex], target, arg, colorMode);

            // Display heatmap
            p.push();
            p.translate(gridX, arg.layout.title_height);
            p.image(gfx_heatmaps[gridIndex], 0, 0);

            // Draw grid lines
            // drawGrid(p, arg);
            p.pop();
        }

        // Draw titles
        // drawTitles();
    }

    function drawTitles() {
        p.fill(255);
        p.noStroke();
        p.textAlign(p.CENTER, p.TOP);
        p.textSize(16);
        p.textStyle(p.BOLD);

        const titles = ["Euclidean Distance", "Manhattan Distance", "Chebyshev Distance"];

        for (let i = 0; i < 3; i++) {
            let gridX = getGridX(i);
            let titleX = gridX + arg.layout.grid_width / 2;
            let titleY = 10;
            p.text(titles[i], titleX, titleY);
        }

        // Draw subtitle with formula
        p.textSize(11);
        p.textStyle(p.NORMAL);
        p.fill(200);

        const subtitles = [
            "d = √(Δx² + Δy²)",
            "d = |Δx| + |Δy|",
            "d = max(|Δx|, |Δy|)"
        ];

        for (let i = 0; i < 3; i++) {
            let gridX = getGridX(i);
            let titleX = gridX + arg.layout.grid_width / 2;
            let titleY = 28;
            p.text(subtitles[i], titleX, titleY);
        }
    }

    function drawGrid(p, arg) {
        p.stroke(60);
        p.strokeWeight(1);
        p.noFill();

        // Draw grid lines
        for (let i = 0; i <= arg.grid.w; i++) {
            p.line(i * arg.grid.tile_size, 0, i * arg.grid.tile_size, arg.grid.h * arg.grid.tile_size);
        }
        for (let i = 0; i <= arg.grid.h; i++) {
            p.line(0, i * arg.grid.tile_size, arg.grid.w * arg.grid.tile_size, i * arg.grid.tile_size);
        }
    }

    function gfx_draw_heatmap_local(p, gfx, node_grid, target, arg, colorMode) {
        gfx.clear();

        for (let y = 0; y < arg.grid.h; y++) {
            for (let x = 0; x < arg.grid.w; x++) {
                let current_node = node_grid[y][x];

                gfx.noStroke();

                if (colorMode === 'hue') {
                    gfx.colorMode(p.HSB);
                    if (current_node.dist == Infinity) {
                        gfx.fill(0, 0, 255);
                    } else if (current_node.isWall) {
                        gfx.fill(0, 0, 0);
                    } else {
                        // Map distance to hue (0-240 for blue to red)
                        let hue = current_node.display_dist * 15;
                        gfx.fill(hue, 200, 200);
                    }
                } else {
                    // Grayscale mode
                    gfx.colorMode(p.RGB);
                    if (current_node.dist == Infinity) {
                        gfx.fill(255);
                    } else if (current_node.isWall) {
                        gfx.fill(0);
                    } else {
                        // Map distance to grayscale (darker = closer)
                        let gray = p.map(current_node.display_dist, 0, 10, 255, 50);
                        gray = p.constrain(gray, 50, 255);
                        gfx.fill(gray);
                    }
                }

                gfx.rect(
                    x * arg.grid.tile_size,
                    y * arg.grid.tile_size,
                    arg.grid.tile_size,
                    arg.grid.tile_size
                );
            }
        }

        // Draw target
        gfx.colorMode(p.RGB);
        gfx.noStroke();
        gfx.fill(0);  // Red target
        gfx.ellipse(
            (target.x + 0.5) * arg.grid.tile_size,
            (target.y + 0.5) * arg.grid.tile_size,
            arg.grid.tile_size,
            arg.grid.tile_size
        );

        
    }
  }  

  setupVisibilityPause(new p5(sketch), 'distanceKernelComparison');
</script>

