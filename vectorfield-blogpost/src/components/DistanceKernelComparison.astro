---
// Distance Kernel Comparison Visualization
const { title = "Distance Kernel Comparison" } = Astro.props;
---

<div class="p5-component">
  <div id="distance_kernel_comparison_canva"></div>
</div>

<script>
  import distance_kernel_comparison_sketch from '../../../scripts/distance_kernel_comparison.js';

  // Initialize p5 instance with the sketch
  const initDistanceKernelComparison = () => {
    if (typeof window !== 'undefined' && window.p5) {
      new p5((p) => distance_kernel_comparison_sketch(p, 'distance_kernel_comparison_canva'));
    }
  };

  // Wait for p5 to be loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDistanceKernelComparison);
  } else {
    initDistanceKernelComparison();
  }
</script>

<style>
  .p5-component {
    margin: 2rem 0;
    display: flex;
    justify-content: center;
  }

  #distance_kernel_comparison_canva {
    border: 2px solid #dee2e6;
    border-radius: 4px;
    overflow: hidden;
    background: white;
  }
</style>
