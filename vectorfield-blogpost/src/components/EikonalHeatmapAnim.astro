---
// Vector Field Heatmap with Eikonal Solver
---

<div class="container">
  <div id="eikonalHeatmap"></div>
  <div class="controls">
    <span>Visualization Mode</span>
    <div class="mode-selector-container">
      <button class="mode-btn" data-mode="hue">HUE heatmap</button>
      <button class="mode-btn" data-mode="grayscale">Grayscale</button>
    </div>
    <div class="checkbox-container">
      <input type="checkbox" id="eikonal-show-values-cb" />
      <label for="eikonal-show-values-cb">Show Values</label>
    </div>
  </div>
</div>

<script>
  import { gfx_draw_grid, gfx_draw_heatmap } from '../common/gfx_function';
  import { eikonal_solver, node } from '../common/solver_function';
  import {
    is_in_grid,
    is_in_screen,
    reset_node_grid,
  } from '../common/utils_function';

  const sketch = (p) => {
    const arg = {
      screen: {
        w: 720,
        h: 480,
      },

      grid: {
        tile_size: 30,
        w: 0,
        h: 0,
        stroke: 100,
        stroke_weight: 1,
      },
    };

    var node_grid;

    var gfx_grid;
    var gfx_heatmap;

    var is_dragging = false;
    var wallpen_state = true;

    var target = {
      x: 0,
      y: 0,
    };

    var heatmap_mode = 'hue';
    var show_values = false;

    p.setup = () => {
      let canva = p.createCanvas(arg.screen.w, arg.screen.h);
      canva.parent('eikonalHeatmap');

      arg.grid.w = p.floor(arg.screen.w / arg.grid.tile_size);
      arg.grid.h = p.floor(arg.screen.h / arg.grid.tile_size);

      node_grid = new Array(arg.grid.h)
        .fill()
        .map((_, y) =>
          new Array(arg.grid.w).fill().map((_, x) => new node(x, y))
        );

      gfx_grid = p.createGraphics(arg.screen.w, arg.screen.h);
      gfx_draw_grid(p, gfx_grid, arg);

      gfx_heatmap = p.createGraphics(arg.screen.w, arg.screen.h);
      eikonal_solver(node_grid, target);

      // UI Event Listeners
      const modeButtons = document.querySelectorAll(
        '#eikonalHeatmap ~ .controls .mode-btn'
      );
      const updateActiveMode = (activeMode) => {
        modeButtons.forEach((btn) => {
          if (btn.getAttribute('data-mode') === activeMode) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });
      };
      updateActiveMode(heatmap_mode);

      modeButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          heatmap_mode = btn.getAttribute('data-mode');
          updateActiveMode(heatmap_mode);
        });
      });

      const showValuesCb = document.getElementById('eikonal-show-values-cb');
      showValuesCb.addEventListener('change', (e) => {
        show_values = e.target.checked;
      });
    };

    p.draw = () => {
      p.image(gfx_heatmap, 0, 0);
      p.image(gfx_grid, 0, 0);

      for (let y = 0; y < node_grid.length; y++) {
        for (let x = 0; x < node_grid[0].length; x++) {
          let current_node = node_grid[y][x];
          current_node.update_display_dist(p, 0.1);

          if (show_values) {
            if (!current_node.isWall && current_node.dist !== Infinity) {
              let textColor;
              if (heatmap_mode === 'hue') {
                let h = (current_node.display_dist * 10) % 360;
                textColor = h > 40 && h < 190 ? 0 : 255;
              } else {
                let brightness = p.map(
                  current_node.display_dist,
                  0,
                  20,
                  255,
                  0
                );
                textColor = brightness > 150 ? 0 : 255;
              }

              p.fill(textColor);
              p.noStroke();
              p.textAlign(p.CENTER, p.CENTER);
              p.textSize(8);
              p.text(
                current_node.display_dist.toFixed(1),
                (x + 0.5) * arg.grid.tile_size,
                (y + 0.5) * arg.grid.tile_size
              );
            }
          }
        }
      }

      gfx_draw_heatmap(
        p,
        gfx_heatmap,
        node_grid,
        target,
        arg,
        heatmap_mode,
        heatmap_mode === 'hue' ? 10 : 20
      );
    };

    p.mouseDragged = () => {
      // Only respond to mouse events if mouse is over the canvas
      if (
        p.mouseX < 0 ||
        p.mouseX > arg.screen.w ||
        p.mouseY < 0 ||
        p.mouseY > arg.screen.h
      )
        return;

      let x = p.floor(p.mouseX / arg.grid.tile_size);
      let y = p.floor(p.mouseY / arg.grid.tile_size);

      if (!is_in_grid(x, y, arg)) return;

      let current_node = node_grid[y][x];

      if (!is_dragging) {
        wallpen_state = !current_node.isWall;
        is_dragging = true;
      }

      current_node.isWall = wallpen_state;
      reset_node_grid(node_grid);
      eikonal_solver(node_grid, target);
    };

    p.mousePressed = () => {
      if (
        p.mouseX < 0 ||
        p.mouseX > arg.screen.w ||
        p.mouseY < 0 ||
        p.mouseY > arg.screen.h
      )
        return;

      let x = p.floor(p.mouseX / arg.grid.tile_size);
      let y = p.floor(p.mouseY / arg.grid.tile_size);

      if (!is_in_grid(x, y, arg)) return;

      let current_node = node_grid[y][x];
      wallpen_state = !current_node.isWall;
      is_dragging = true;

      current_node.isWall = wallpen_state;
      reset_node_grid(node_grid);
      eikonal_solver(node_grid, target);
    };

    p.mouseReleased = () => {
      if (is_dragging) is_dragging = false;
    };

    p.mouseMoved = () => {
      // Only respond to mouse events if mouse is over the canvas
      if (
        p.mouseX < 0 ||
        p.mouseX > arg.screen.w ||
        p.mouseY < 0 ||
        p.mouseY > arg.screen.h
      )
        return;
      if (!is_in_screen(p.mouseX, p.mouseY, arg)) return;
      let grid_x = p.floor(p.mouseX / arg.grid.tile_size);
      let grid_y = p.floor(p.mouseY / arg.grid.tile_size);

      target.x = grid_x;
      target.y = grid_y;
      reset_node_grid(node_grid);
      eikonal_solver(node_grid, target);
    };
  };

  new p5(sketch);
</script>

<style>
  #eikonalHeatmap {
    line-height: 0;
    background-color: #1a1a1a;
    background-image:
      linear-gradient(45deg, #222 25%, transparent 25%),
      linear-gradient(-45deg, #222 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #222 75%),
      linear-gradient(-45deg, transparent 75%, #222 75%);
    background-size: 20px 20px;
    background-position:
      0 0,
      0 10px,
      10px -10px,
      -10px 0px;
    border-radius: 4px;
    overflow: hidden;
  }

  .container {
    display: flex;
    flex-direction: row;
    gap: 20px;
    padding: 20px;
    background: #111;
    border-radius: 12px;
  }

  .controls {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 15px;
    min-width: 200px;
  }

  .mode-selector-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 15px;
  }

  .checkbox-container {
    margin-top: 5px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: white;
  }

  .checkbox-container input {
    width: 18px;
    height: 18px;
    cursor: pointer;
  }

  span {
    display: block;
    color: #ccc;
    font-size: 0.8em;
    margin-bottom: 5px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }

  button {
    background: #333;
    border: 1px solid #555;
    color: white;
    padding: 10px 12px;
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 6px;
    text-align: left;
    font-size: 0.9em;
  }

  button:hover {
    background: #444;
  }

  button.active {
    background: #007aff;
    border-color: #0056b3;
    box-shadow: 0 0 10px rgba(0, 122, 255, 0.3);
  }
</style>
