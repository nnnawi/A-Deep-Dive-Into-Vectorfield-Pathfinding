---
// Grid Dijkstra Animation
const { title = "Dijkstra Algorithm Animation" } = Astro.props;
---

<div class="p5-component">
  <div id="grid_djikstra_animation_canva"></div>
</div>

<script>
  import grid_djikstra_animation_sketch from '../../../scripts/grid_djikstra_animation.js';

  // Initialize p5 instance with the sketch
  const initGridDijkstraAnimation = () => {
    if (typeof window !== 'undefined' && window.p5) {
      new p5((p) => grid_djikstra_animation_sketch(p, 'grid_djikstra_animation_canva'));
    }
  };

  // Wait for p5 to be loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGridDijkstraAnimation);
  } else {
    initGridDijkstraAnimation();
  }
</script>

<style>
  .p5-component {
    margin: 2rem 0;
    display: flex;
    justify-content: center;
  }

  #grid_djikstra_animation_canva {
    border: 2px solid #dee2e6;
    border-radius: 4px;
    overflow: hidden;
    background: white;
  }
</style>
