---
// Interactive Wave Simulation with p5.js
const { title = 'Wave Interference Simulation' } = Astro.props;
---

<div class="p5-component">
  <h3>{title}</h3>
  <div class="p5-container">
    <div class="controls">
      <div class="control-group">
        <label for="amplitude"
          >Amplitude: <span id="amplitudeValue">30</span></label
        >
        <input
          type="range"
          id="amplitude"
          min="10"
          max="50"
          step="5"
          value="30"
        />
      </div>

      <div class="control-group">
        <label for="frequency"
          >Frequency: <span id="frequencyValue">0.05</span></label
        >
        <input
          type="range"
          id="frequency"
          min="0.01"
          max="0.1"
          step="0.01"
          value="0.05"
        />
      </div>

      <div class="control-group">
        <label for="speed">Speed: <span id="speedValue">0.1</span></label>
        <input
          type="range"
          id="speed"
          min="0.05"
          max="0.2"
          step="0.01"
          value="0.1"
        />
      </div>

      <div class="control-group">
        <label>
          <input type="checkbox" id="show3D" />
          3D Perspective
        </label>
      </div>

      <div class="control-group">
        <label>
          <input type="checkbox" id="showColor" checked />
          Color Mode
        </label>
      </div>
    </div>

    <div id="wave-canvas"></div>
  </div>
</div>

<script>
  // p5 is loaded globally from the Layout
  let amplitude = 30;
  let frequency = 0.05;
  let speed = 0.1;
  let show3D = false;
  let showColor = true;
  let time = 0;

  const sketch = (p) => {
    p.setup = () => {
      const canvas = p.createCanvas(600, 400, show3D ? p.WEBGL : p.P2D);
      canvas.parent('wave-canvas');
    };

    p.draw = () => {
      p.background(20);

      time += speed;

      const cols = 50;
      const rows = 50;
      const cellWidth = p.width / cols;
      const cellHeight = p.height / rows;

      if (show3D) {
        // 3D mode
        p.rotateX(p.PI / 3);
        p.translate(-p.width / 2, -p.height / 2, 0);

        for (let i = 0; i < cols; i++) {
          for (let j = 0; j < rows; j++) {
            const x = i * cellWidth;
            const y = j * cellHeight;

            const d1 = p.dist(x, y, p.width * 0.3, p.height * 0.3);
            const d2 = p.dist(x, y, p.width * 0.7, p.height * 0.7);

            const wave1 = p.sin(d1 * frequency + time) * amplitude;
            const wave2 = p.sin(d2 * frequency + time) * amplitude;
            const z = wave1 + wave2;

            p.push();
            p.translate(x, y, z);

            if (showColor) {
              const hue = p.map(z, -amplitude * 2, amplitude * 2, 180, 360);
              p.fill(hue, 80, 90);
            } else {
              p.fill(200);
            }

            p.noStroke();
            p.box(cellWidth * 0.8, cellHeight * 0.8, 5);
            p.pop();
          }
        }
      } else {
        // 2D mode
        p.noStroke();

        for (let i = 0; i < cols; i++) {
          for (let j = 0; j < rows; j++) {
            const x = i * cellWidth;
            const y = j * cellHeight;

            const d1 = p.dist(x, y, p.width * 0.3, p.height * 0.3);
            const d2 = p.dist(x, y, p.width * 0.7, p.height * 0.7);

            const wave1 = p.sin(d1 * frequency + time) * amplitude;
            const wave2 = p.sin(d2 * frequency + time) * amplitude;
            const intensity = wave1 + wave2;

            if (showColor) {
              const hue = p.map(
                intensity,
                -amplitude * 2,
                amplitude * 2,
                200,
                60
              );
              const brightness = p.map(
                intensity,
                -amplitude * 2,
                amplitude * 2,
                30,
                100
              );
              p.fill(hue, 80, brightness);
            } else {
              const gray = p.map(
                intensity,
                -amplitude * 2,
                amplitude * 2,
                0,
                255
              );
              p.fill(gray);
            }

            p.rect(x, y, cellWidth, cellHeight);
          }
        }
      }
    };
  };

  let myp5 = new p5(sketch);

  // Control event listeners
  document.getElementById('amplitude')?.addEventListener('input', (e) => {
    amplitude = parseFloat(e.target.value);
    document.getElementById('amplitudeValue').textContent = amplitude;
  });

  document.getElementById('frequency')?.addEventListener('input', (e) => {
    frequency = parseFloat(e.target.value);
    document.getElementById('frequencyValue').textContent =
      frequency.toFixed(2);
  });

  document.getElementById('speed')?.addEventListener('input', (e) => {
    speed = parseFloat(e.target.value);
    document.getElementById('speedValue').textContent = speed.toFixed(2);
  });

  document.getElementById('show3D')?.addEventListener('change', (e) => {
    show3D = e.target.checked;
    // Recreate canvas with new renderer
    myp5.remove();
    myp5 = new p5(sketch);
  });

  document.getElementById('showColor')?.addEventListener('change', (e) => {
    showColor = e.target.checked;
  });
</script>

<style>
  .p5-component {
    margin: 3rem 0;
    padding: 2rem;
    background: #f8f9fa;
    border-radius: 8px;
    border: 1px solid #dee2e6;
  }

  .p5-component h3 {
    margin-top: 0;
    color: #2c3e50;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .p5-container {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .controls {
    flex: 0 0 250px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .control-group label {
    font-weight: 500;
    color: #495057;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .control-group input[type='range'] {
    width: 100%;
    cursor: pointer;
  }

  .control-group input[type='checkbox'] {
    cursor: pointer;
  }

  #wave-canvas {
    flex: 1;
    border: 2px solid #dee2e6;
    border-radius: 4px;
    overflow: hidden;
    background: #1a1a1a;
  }

  @media (max-width: 768px) {
    .p5-container {
      flex-direction: column;
    }

    .controls {
      flex: 1;
      width: 100%;
    }
  }
</style>
