---
// Vector Field Heatmap with Distance Matrix
const { title = "Vector Field Heatmap - Distance Matrix" } = Astro.props;
---

<div class="p5-component">
  <div id="vf_heatmap_distance_matrix_canva"></div>
</div>

<script>
  import vf_heatmap_distance_matrix_sketch from '../../../scripts/vf_heatmap_distance_matrix.js';

  // Initialize p5 instance with the sketch
  const initVfHeatmapDistanceMatrix = () => {
    if (typeof window !== 'undefined' && window.p5) {
      new p5((p) => vf_heatmap_distance_matrix_sketch(p, 'vf_heatmap_distance_matrix_canva'));
    }
  };

  // Wait for p5 to be loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initVfHeatmapDistanceMatrix);
  } else {
    initVfHeatmapDistanceMatrix();
  }
</script>

<style>
  .p5-component {
    margin: 2rem 0;
    display: flex;
    justify-content: center;
  }

  #vf_heatmap_distance_matrix_canva {
    border: 2px solid #dee2e6;
    border-radius: 4px;
    overflow: hidden;
    background: white;
  }
</style>
