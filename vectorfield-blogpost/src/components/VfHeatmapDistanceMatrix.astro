---
// Vector Field Heatmap with Distance Matrix
---

<div class="container">
  <div id="canva"></div>
  <div class="controls">
    <div class="distance-controls">
      <label>
        <input type="radio" name="distance" value="Manhattan" checked /> Manhattan
      </label>
      <label>
        <input type="radio" name="distance" value="Euclidian" /> Euclidian
      </label>
      <label>
        <input type="radio" name="distance" value="Tchebishev" /> Tchebyshev
      </label>
    </div>
    <div class="dynamic-target-control">
      <label>
        <input type="checkbox" id="dynamic-target-toggle" /> Dynamic Target Node
      </label>
    </div>
  </div>
</div>

<script>
  import {
    gfx_draw_grid,
    gfx_draw_heatmap,
  } from '../../../scripts/gfx_function.js';
  import {
    djikstra_algorithm,
    node,
  } from '../../../scripts/solver_function.js';
  import {
    is_in_grid,
    is_in_screen,
    reset_node_grid,
  } from '../../../scripts/utils_function.js';
  import { dist_arr } from '../common/constant';

  const arg = {
    screen: {
      w: 720,
      h: 480,
    },

    grid: {
      tile_size: 30,
      w: 0,
      h: 0,
      stroke: 100,
      stroke_weight: 1,
    },
  };

  var node_grid;
  var current_distance = 'Tchebishev'; // Default distance metric

  var is_dragging = false;
  var wallpen_state = true;

  var gfx_grid;
  var gfx_heatmap;

  var target = {
    x: 0,
    y: 0,
  };

  const sketch = (p) => {
    p.setup = () => {
      let canvas = p.createCanvas(arg.screen.w, arg.screen.h);
      canvas.parent('canva');

      arg.grid.w = p.floor(arg.screen.w / arg.grid.tile_size);
      arg.grid.h = p.floor(arg.screen.h / arg.grid.tile_size);

      node_grid = new Array(arg.grid.h)
        .fill()
        .map((_, y) =>
          new Array(arg.grid.w).fill().map((_, x) => new node(x, y))
        );

      gfx_grid = p.createGraphics(arg.screen.w, arg.screen.h);
      gfx_draw_grid(p, gfx_grid, arg);

      gfx_heatmap = p.createGraphics(arg.screen.w, arg.screen.h);
      djikstra_algorithm(node_grid, target, dist_arr[current_distance], arg);

      // Add event listener for radio buttons
      const radioButtons = document.querySelectorAll('input[name="distance"]');
      radioButtons.forEach((radio) => {
        radio.addEventListener('change', (e) => {
          current_distance = e.target.value;
          reset_node_grid(node_grid);
          djikstra_algorithm(
            node_grid,
            target,
            dist_arr[current_distance],
            arg
          );
        });
      });
    };

    p.draw = () => {
      p.background(0);
      p.image(gfx_heatmap, 0, 0);
      p.image(gfx_grid, 0, 0);

      for (let y = 0; y < node_grid.length; y++) {
        for (let x = 0; x < node_grid[0].length; x++) {
          node_grid[y][x].update_display_dist(p, 0.05);
        }
      }

      gfx_draw_heatmap(p, gfx_heatmap, node_grid, target, arg);
    };

    p.mouseMoved = () => {
      // Only respond to mouse events if mouse is over the canvas
      if (
        p.mouseX < 0 ||
        p.mouseX > arg.screen.w ||
        p.mouseY < 0 ||
        p.mouseY > arg.screen.h
      )
        return;
      if (is_in_screen(p.mouseX, p.mouseY, arg)) {
        let grid_x = p.floor(p.mouseX / arg.grid.tile_size);
        let grid_y = p.floor(p.mouseY / arg.grid.tile_size);

        target.x = grid_x;
        target.y = grid_y;
        reset_node_grid(node_grid);
        djikstra_algorithm(node_grid, target, dist_arr[current_distance], arg);
      }
    };

    p.mouseDragged = () => {
      // Only respond to mouse events if mouse is over the canvas
      if (
        p.mouseX < 0 ||
        p.mouseX > arg.screen.w ||
        p.mouseY < 0 ||
        p.mouseY > arg.screen.h
      )
        return;

      let x = p.floor(p.mouseX / arg.grid.tile_size);
      let y = p.floor(p.mouseY / arg.grid.tile_size);

      if (!is_in_grid(x, y, arg)) return;

      let current_node = node_grid[y][x];

      if (!is_dragging) {
        wallpen_state = !current_node.isWall;
        is_dragging = true;
      }

      current_node.isWall = wallpen_state;
      reset_node_grid(node_grid);
      djikstra_algorithm(node_grid, target, dist_arr[current_distance], arg);
    };

    p.mouseReleased = () => {
      if (is_dragging) is_dragging = false;
    };
  };

  new p5(sketch);
</script>

<style>
  .container {
    display: flex;
    flex-direction: row;
  }

  .controls {
    display: flex;
    flex-direction: column;
  }

  /* Hide the native radio input */
  input[type='radio'] {
    appearance: none;
    opacity: 0;
    position: absolute;
  }

  label {
    position: relative;
    padding: 48px 16px;
    border-radius: 8px;
    box-shadow: 2px 2px 6px 0px var(--grey);
  }

  label::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    right: 16px;
    top: 16px;
    background: var(--grey);
  }

  /* When the radio is checked, style the label accordingly */
  input[type='radio']:checked + label {
    background: red;
    outline: solid 3px var(--blue);
  }

  /* When the radio is focused, style the label accordingly */
  input[type='radio']:focus + label {
    outline-offset: 3px;
  }

  /* When the radio is checked, style the pseudo-element accordingly */
  input[type='radio']:checked + label::after {
    background: red;
  }
</style>
