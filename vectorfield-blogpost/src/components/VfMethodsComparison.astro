---
// Vector Field Methods Comparison
const { title = "Vector Field Methods Comparison" } = Astro.props;
---

<div class="p5-component">
  <div id="vf_methods_comparison_canva"></div>
</div>

<script>
  import vf_comparison_sketch from '../../../scripts/vf_methods_comparison.js';

  // Initialize p5 instance with the sketch
  const initVfMethodsComparison = () => {
    if (typeof window !== 'undefined' && window.p5) {
      new p5((p) => vf_comparison_sketch(p, 'vf_methods_comparison_canva'));
    }
  };

  // Wait for p5 to be loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initVfMethodsComparison);
  } else {
    initVfMethodsComparison();
  }
</script>

<style>
  .p5-component {
    margin: 2rem 0;
    display: flex;
    justify-content: center;
  }

  #vf_methods_comparison_canva {
    border: 2px solid #dee2e6;
    border-radius: 4px;
    overflow: hidden;
    background: white;
  }
</style>
