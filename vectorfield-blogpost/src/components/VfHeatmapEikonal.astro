---
// Vector Field Heatmap with Eikonal Solver
const { title = 'Vector Field Heatmap - Eikonal' } = Astro.props;
---

<div class="p5-component">
  <div id="vf_heatmap_eikonal_canva"></div>
</div>

<script>
  import vf_heatmap_eikonal_sketch from '../../../scripts/vf_heatmap_eikonal.js';

  // Initialize p5 instance with the sketch
  const initVfHeatmapEikonal = () => {
    if (typeof window !== 'undefined' && window.p5) {
      new p5((p) => vf_heatmap_eikonal_sketch(p, 'vf_heatmap_eikonal_canva'));
    }
  };

  // Wait for p5 to be loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initVfHeatmapEikonal);
  } else {
    initVfHeatmapEikonal();
  }
</script>

<style>
  .p5-component {
    margin: 2rem 0;
    display: flex;
    justify-content: center;
  }

  #vf_heatmap_eikonal_canva {
    border: 2px solid #dee2e6;
    border-radius: 4px;
    overflow: hidden;
    background: white;
  }
</style>
