---
// Graph Grid Relation Visualization
---

<div id="graphGridRelationAnim"></div>

<script>
  const sketch = (p) => {
    let gridSize = 6;
    let nodeRadius = 15;
    let spacing = 50;
    let offsetX = 70;
    let offsetY = 25;
    let graphOffsetX = 450;

    // Track which cells are walls (true = wall, false = open)
    let wallArray = Array(gridSize)
      .fill()
      .map(() => Array(gridSize).fill(false));

    // Track dragging state
    let isDragging = false;
    let dragMode = null; // 'create' for creating walls, 'erase' for removing walls
    let lastDraggedCell = { row: -1, col: -1 };

    // Animation tracking for nodes
    let nodeAnimations = {}; // key: "row-col", value: {scale, opacity, isAppearing}

    // Distance kernel
    let distanceKernel = [
      [2, 1, 2],
      [1, 1, 1],
      [2, 1, 2],
    ];

    function getNodeKey(row, col) {
      return `${row}-${col}`;
    }

    function getEdgeWeight(fromRow, fromCol, toRow, toCol) {
      let deltaRow = toRow - fromRow;
      let deltaCol = toCol - fromCol;

      // Convert delta to kernel indices (add 1 to shift from [-1,1] to [0,2])
      let kernelRow = deltaRow + 1;
      let kernelCol = deltaCol + 1;

      return distanceKernel[kernelRow][kernelCol];
    }

    p.setup = () => {
      let canvas = p.createCanvas(780, 350);
      canvas.parent('graphGridRelationAnim');
    };

    p.draw = () => {
      p.clear();

      // Update node animations
      updateNodeAnimations();

      // Draw 2D grid on the left
      drawGrid2D();

      // Draw 8-connected graph on the right
      p.translate(0, spacing / 2);
      drawGraph8Connected();
    };

    function drawGrid2D() {
      // Draw grid lines
      p.stroke(50);
      p.strokeWeight(3);

      for (let x = 0; x <= gridSize; x++) {
        let lineX = offsetX + x * spacing;
        p.line(lineX, offsetY, lineX, offsetY + gridSize * spacing);
      }
      for (let y = 0; y <= gridSize; y++) {
        let lineY = offsetY + y * spacing;
        p.line(offsetX, lineY, offsetX + gridSize * spacing, lineY);
      }

      // Draw cells (walls and open spaces)
      for (let row = 0; row < gridSize; row++) {
        for (let col = 0; col < gridSize; col++) {
          let x = offsetX + col * spacing;
          let y = offsetY + row * spacing;

          if (wallArray[row][col]) {
            // Draw wall
            p.fill(60);
            p.noStroke();
            p.rect(x + 1, y + 1, spacing - 2, spacing - 2);
          } else {
            // Draw open space with node number
            p.fill(250);
            p.noStroke();
            p.rect(x + 1, y + 1, spacing - 2, spacing - 2);

            // Add node number
            let nodeIndex = row * gridSize + col;
            p.fill(100);
            p.textAlign(p.CENTER, p.CENTER);
            p.textSize(12);
            p.text(nodeIndex, x + spacing / 2, y + spacing / 2);
          }
        }
      }
    }

    function drawGraph8Connected() {
      // First, draw all edges between non-wall nodes
      p.strokeWeight(1.5);

      for (let row = 0; row < gridSize; row++) {
        for (let col = 0; col < gridSize; col++) {
          // Skip if current cell is a wall
          if (wallArray[row][col]) continue;

          let nodeKey = getNodeKey(row, col);
          let anim = nodeAnimations[nodeKey];

          // Skip if node is disappearing or has very low opacity
          if (anim && !anim.isAppearing && anim.opacity < 0.3) continue;

          let x = graphOffsetX + col * spacing;
          let y = offsetY + row * spacing;

          // Check all 8 directions
          let directions = [
            [-1, -1],
            [-1, 0],
            [-1, 1], // top-left, top, top-right
            [0, -1],
            [0, 1], // left, right
            [1, -1],
            [1, 0],
            [1, 1], // bottom-left, bottom, bottom-right
          ];

          for (let [dRow, dCol] of directions) {
            let newRow = row + dRow;
            let newCol = col + dCol;

            // Check bounds and if target is not a wall
            if (
              newRow >= 0 &&
              newRow < gridSize &&
              newCol >= 0 &&
              newCol < gridSize &&
              !wallArray[newRow][newCol]
            ) {
              let targetKey = getNodeKey(newRow, newCol);
              let targetAnim = nodeAnimations[targetKey];

              // Skip if target node is disappearing or has very low opacity
              if (
                targetAnim &&
                !targetAnim.isAppearing &&
                targetAnim.opacity < 0.3
              )
                continue;

              let targetX = graphOffsetX + newCol * spacing;
              let targetY = offsetY + newRow * spacing;

              // Only draw each edge once (avoid duplicates)
              if (newRow > row || (newRow === row && newCol > col)) {
                // Get edge weight
                let weight = getEdgeWeight(row, col, newRow, newCol);

                // Calculate edge opacity based on both nodes
                let edgeOpacity = 100;
                if (anim) {
                  edgeOpacity = p.map(anim.opacity, 0, 1, 0, 100);
                }
                if (targetAnim) {
                  let targetEdgeOpacity = p.map(
                    targetAnim.opacity,
                    0,
                    1,
                    0,
                    100
                  );
                  edgeOpacity = Math.min(edgeOpacity, targetEdgeOpacity);
                }

                // Draw edge with different colors based on weight
                if (weight === 1) {
                  p.stroke(50, 150, 50, edgeOpacity); // Green for weight 1
                } else {
                  p.stroke(150, 50, 50, edgeOpacity); // Red for weight 2
                }

                p.line(x, y, targetX, targetY);

                // Draw edge weight label
                let midX = (x + targetX) / 2;
                let midY = (y + targetY) / 2;

                // Create a small background for the weight text
                p.fill(255, edgeOpacity * 0.8);
                p.noStroke();
                p.ellipse(midX, midY, 16, 16);

                // Draw weight text
                p.fill(
                  weight === 1
                    ? p.color(0, 100, 0, edgeOpacity)
                    : p.color(100, 0, 0, edgeOpacity)
                );
                p.textAlign(p.CENTER, p.CENTER);
                p.textSize(10);
                p.text(weight, midX, midY);
              }
            }
          }
        }
      }

      // Then draw nodes on top of edges
      for (let row = 0; row < gridSize; row++) {
        for (let col = 0; col < gridSize; col++) {
          // Skip wall nodes, but draw disappearing nodes until animation completes
          let nodeKey = getNodeKey(row, col);
          let anim = nodeAnimations[nodeKey];

          if (wallArray[row][col] && (!anim || anim.opacity <= 0)) continue;

          let x = graphOffsetX + col * spacing;
          let y = offsetY + row * spacing;
          let nodeIndex = row * gridSize + col;

          // Default values
          let scale = 1.0;
          let opacity = 255;

          // Apply animation if exists
          if (anim) {
            scale = anim.scale;
            opacity = p.map(anim.opacity, 0, 1, 0, 255);
          }

          let animatedRadius = nodeRadius * scale;

          // Draw node circle with animation
          p.fill(255, opacity);
          p.stroke(50, opacity);
          p.strokeWeight(2);
          p.ellipse(x, y, animatedRadius * 2, animatedRadius * 2);

          // Draw node label with animation
          p.fill(50, opacity);
          p.noStroke();
          p.textAlign(p.CENTER, p.CENTER);
          p.textSize(12 * scale);
          p.text(nodeIndex, x, y);
        }
      }
    }

    // Handle mouse interactions for toggling walls
    p.mousePressed = () => {
      // Only respond to mouse events if mouse is over the canvas
      if (
        p.mouseX < 0 ||
        p.mouseX > p.width ||
        p.mouseY < 0 ||
        p.mouseY > p.height
      )
        return;
      startDragging();
    };

    p.mouseDragged = () => {
      // Only respond to mouse events if mouse is over the canvas
      if (
        p.mouseX < 0 ||
        p.mouseX > p.width ||
        p.mouseY < 0 ||
        p.mouseY > p.height
      )
        return;
      continueDragging();
    };

    p.mouseReleased = () => {
      stopDragging();
    };

    function startDragging() {
      // Check if mouse is over the left grid
      if (
        p.mouseX >= offsetX &&
        p.mouseX <= offsetX + gridSize * spacing &&
        p.mouseY >= offsetY &&
        p.mouseY <= offsetY + gridSize * spacing
      ) {
        let gridCol = p.floor((p.mouseX - offsetX) / spacing);
        let gridRow = p.floor((p.mouseY - offsetY) / spacing);

        // Ensure we're within bounds
        if (
          gridRow >= 0 &&
          gridRow < gridSize &&
          gridCol >= 0 &&
          gridCol < gridSize
        ) {
          isDragging = true;

          // Determine drag mode based on current cell state
          dragMode = wallArray[gridRow][gridCol] ? 'erase' : 'create';

          // Toggle the cell and trigger animation
          let wasWall = wallArray[gridRow][gridCol];
          wallArray[gridRow][gridCol] = !wallArray[gridRow][gridCol];
          triggerNodeAnimation(gridRow, gridCol, !wasWall);

          // Remember this cell
          lastDraggedCell = { row: gridRow, col: gridCol };
        }
      }
    }

    function continueDragging() {
      if (!isDragging) return;

      // Check if mouse is over the left grid
      if (
        p.mouseX >= offsetX &&
        p.mouseX <= offsetX + gridSize * spacing &&
        p.mouseY >= offsetY &&
        p.mouseY <= offsetY + gridSize * spacing
      ) {
        let gridCol = p.floor((p.mouseX - offsetX) / spacing);
        let gridRow = p.floor((p.mouseY - offsetY) / spacing);

        // Ensure we're within bounds and it's a different cell
        if (
          gridRow >= 0 &&
          gridRow < gridSize &&
          gridCol >= 0 &&
          gridCol < gridSize
        ) {
          if (
            gridRow !== lastDraggedCell.row ||
            gridCol !== lastDraggedCell.col
          ) {
            let wasWall = wallArray[gridRow][gridCol];

            // Apply the same mode to this cell
            if (dragMode === 'create' && !wasWall) {
              wallArray[gridRow][gridCol] = true;
              triggerNodeAnimation(gridRow, gridCol, true); // disappearing
            } else if (dragMode === 'erase' && wasWall) {
              wallArray[gridRow][gridCol] = false;
              triggerNodeAnimation(gridRow, gridCol, false); // appearing
            }

            // Update last dragged cell
            lastDraggedCell = { row: gridRow, col: gridCol };
          }
        }
      }
    }

    function stopDragging() {
      isDragging = false;
      dragMode = null;
      lastDraggedCell = { row: -1, col: -1 };
    }

    // Add a clear button functionality with spacebar
    p.keyPressed = () => {
      if (p.key === ' ') {
        // Clear all walls and trigger animations for appearing nodes
        for (let row = 0; row < gridSize; row++) {
          for (let col = 0; col < gridSize; col++) {
            if (wallArray[row][col]) {
              wallArray[row][col] = false;
              triggerNodeAnimation(row, col, false); // appearing
            }
          }
        }
      }
    };

    // Animation functions
    function triggerNodeAnimation(row, col, isDisappearing) {
      let nodeKey = getNodeKey(row, col);

      if (isDisappearing) {
        // Node is disappearing (becoming a wall)
        nodeAnimations[nodeKey] = {
          scale: 1.0,
          opacity: 1.0,
          isAppearing: false,
          startTime: p.millis(),
        };
      } else {
        // Node is appearing (wall being removed)
        nodeAnimations[nodeKey] = {
          scale: 0.0,
          opacity: 0.0,
          isAppearing: true,
          startTime: p.millis(),
        };
      }
    }

    function updateNodeAnimations() {
      let currentTime = p.millis();
      let animationDuration = 300; // 300ms animation

      Object.keys(nodeAnimations).forEach((nodeKey) => {
        let anim = nodeAnimations[nodeKey];
        let elapsed = currentTime - anim.startTime;
        let progress = Math.min(elapsed / animationDuration, 1.0);

        // Use easing function for smoother animation
        let easedProgress = easeOutBack(progress);

        if (anim.isAppearing) {
          // Node appearing: scale and opacity go from 0 to 1
          anim.scale = easedProgress * 1.2; // Overshoot to 1.2x
          if (progress > 0.7) {
            // Scale back down to 1.0 in the last 30% of animation
            let scaleBackProgress = (progress - 0.7) / 0.3;
            anim.scale = 1.2 - scaleBackProgress * 0.2;
          }
          anim.opacity = easedProgress;
        } else {
          // Node disappearing: reverse of appearing animation
          // Start at 1.0, go up to 1.2, then shrink to 0
          if (progress <= 0.3) {
            // First 30%: grow from 1.0 to 1.2 (reverse pop)
            let growProgress = progress / 0.3;
            anim.scale = 1.0 + easeOutBack(growProgress) * 0.2;
          } else {
            // Last 70%: shrink from 1.2 to 0
            let shrinkProgress = (progress - 0.3) / 0.7;
            anim.scale = 1.2 - easeOutBack(shrinkProgress) * 1.2;
          }
          anim.opacity = 1.0 - easedProgress;
        }

        // Clean up completed animations
        if (progress >= 1.0) {
          if (anim.isAppearing) {
            anim.scale = 1.0;
            anim.opacity = 1.0;
          }
          delete nodeAnimations[nodeKey];
        }
      });
    }

    // Easing function for smooth pop animation
    function easeOutBack(t) {
      let c1 = 1.70158;
      let c3 = c1 + 1;
      return 1 + c3 * Math.pow(t - 1, 3) + c1 * Math.pow(t - 1, 2);
    }
  };

  new p5(sketch);
</script>
