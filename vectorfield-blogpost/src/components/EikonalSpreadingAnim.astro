---
// Eikonal Spreading Animation
---

<div class="eikonal-container">
  <div id="eikonalSpreadingAnim"></div>
  <div class="controls">
    <div class="single-control">
      <span>Animation Progress</span>
      <div class="progress-row">
        <div class="button-group">
          <button id="play-pause-btn" aria-label="Play">
            <svg id="play-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
            <svg id="pause-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
          </button>
        </div>
        <div class="slider-wrapper">
          <input
            type="range"
            id="time-slider"
            min="0"
            max="100"
            value="0"
            step="1"
          />
        </div>
      </div>
    </div>

    <div class="single-control">
      <span>Utility</span>
      <div class="button-group">
        <button id="change-seed-btn">Randomize walls</button>
      </div>
    </div>
  </div>
</div>

<script>
  import { gfx_draw_grid } from '../common/gfx_function';
import { setupVisibilityPause } from '../common/p5_utils';
import { node } from '../common/solver_function';

  const arg = {
  screen: {
      w: 500,
      h: 450,
    },
    grid: {
      tile_size: 15,
      w: 0,
      h: 0,
      stroke: 200,
      stroke_weight: 1,
    },
  };

  var node_grid;
  var gfx_grid: any;
  var gfx_heatmap: any;
  var target = { x: 0, y: 0 };
  var timeSteps = [];
  var currentTimeStep = 0;
  var maxTimeSteps = 0;
  var is_dragging = false;
  var wallpen_state = true;
  var isPlaying = false;
  var playDirection = 1;
  var playInterval: ReturnType<typeof setInterval> | null = null;

  const sketch = (p) => {
    p.setup = () => {
      const container = document.getElementById('djikstraHeatmapAnim');
      arg.screen.w = container.offsetWidth + 20;

      let canvas = p.createCanvas(arg.screen.w, arg.screen.h);
      canvas.parent('eikonalSpreadingAnim');

      arg.grid.w = p.floor(arg.screen.w / arg.grid.tile_size);
      arg.grid.h = p.floor(arg.screen.h / arg.grid.tile_size);

      node_grid = new Array(arg.grid.h)
        .fill()
        .map((_, y) =>
          new Array(arg.grid.w).fill().map((_, x) => new node(x, y))
        );

      generateRandomWalls();
      target.x = p.floor(arg.grid.w / 2);
      target.y = p.floor(arg.grid.h / 2);
      node_grid[target.y][target.x].isWall = false;

      gfx_grid = p.createGraphics(arg.screen.w, arg.screen.h);
      gfx_draw_grid(p, gfx_grid, arg);

      gfx_heatmap = p.createGraphics(arg.screen.w, arg.screen.h);
      solveEikonalWithTimeSteps();
      updateHeatmapFromTimeStep();

      setupUIListeners();
    };

    function setupUIListeners() {
      const timeSlider = document.getElementById('time-slider') as HTMLInputElement;
      const changeSeedBtn = document.getElementById('change-seed-btn');
      const playPauseBtn = document.getElementById('play-pause-btn')!;

      const playIcon = document.getElementById('play-icon')! as HTMLElement;
      const pauseIcon = document.getElementById('pause-icon')! as HTMLElement;

      function startPlayback() {
        isPlaying = true;
        playIcon.style.display = 'none';
        pauseIcon.style.display = '';
        playPauseBtn.classList.add('active');
        playInterval = setInterval(() => {
          currentTimeStep += playDirection;
          if (currentTimeStep >= maxTimeSteps - 1) {
            currentTimeStep = maxTimeSteps - 1;
            playDirection = -1;
          } else if (currentTimeStep <= 0) {
            currentTimeStep = 0;
            playDirection = 1;
          }
          timeSlider.value = String(Math.round((currentTimeStep / (maxTimeSteps - 1)) * 100));
          updateHeatmapFromTimeStep();
        }, 25);
      }

      function stopPlayback() {
        isPlaying = false;
        playIcon.style.display = '';
        pauseIcon.style.display = 'none';
        playPauseBtn.classList.remove('active');
        clearInterval(playInterval ?? undefined);
        playInterval = null;
      }

      playPauseBtn.addEventListener('click', () => {
        if (isPlaying) stopPlayback();
        else startPlayback();
      });

      timeSlider.addEventListener('input', (e) => {
        if (isPlaying) stopPlayback();
        const value = parseInt((e.target as HTMLInputElement).value);
        currentTimeStep = Math.floor((value / 100) * (maxTimeSteps - 1));
        updateHeatmapFromTimeStep();
      });

      changeSeedBtn.addEventListener('click', () => {
        stopPlayback();
        resetGrid();
        generateRandomWalls();
        target.x = p.floor(arg.grid.w / 2);
        target.y = p.floor(arg.grid.h / 2);
        node_grid[target.y][target.x].isWall = false;
        reSolveAndResetUI();
      });
    }

    function resetGrid() {
      for (let y = 0; y < arg.grid.h; y++) {
        for (let x = 0; x < arg.grid.w; x++) {
          node_grid[y][x].isWall = false;
        }
      }
    }

    function reSolveAndResetUI() {
      solveEikonalWithTimeSteps();
      currentTimeStep = 0;
      const timeSlider = document.getElementById('time-slider');
      timeSlider.value = 0;
      updateHeatmapFromTimeStep();
    }

    function generateRandomWalls() {
      const minClearRadius = 8;
      const centerX = arg.grid.w / 2;
      const centerY = arg.grid.h / 2;
      const minWallSpacing = 7;

      let verticalWallPositions = [];
      let horizontalWallPositions = [];

      const numVerticalWalls = 4 + Math.floor(Math.random() * 3);
      for (let i = 0; i < numVerticalWalls; i++) {
        let x;
        let attempts = 0;
        do {
          x = Math.floor(Math.random() * arg.grid.w);
          attempts++;
        } while (
          attempts < 50 &&
          verticalWallPositions.some(
            (pos) => Math.abs(pos - x) < minWallSpacing
          )
        );

        if (attempts >= 50) continue;
        verticalWallPositions.push(x);

        const startY = Math.floor(Math.random() * arg.grid.h * 0.2);
        const height = Math.floor(
          arg.grid.h * 0.4 + Math.random() * arg.grid.h * 0.4
        );

        for (let y = startY; y < Math.min(startY + height, arg.grid.h); y++) {
          const dist = Math.sqrt(
            Math.pow(x - centerX, 2) + Math.pow(y - centerY, 2)
          );
          if (dist > minClearRadius) {
            node_grid[y][x].isWall = true;
          }
        }
      }

      const numHorizontalWalls = 4 + Math.floor(Math.random() * 3);
      for (let i = 0; i < numHorizontalWalls; i++) {
        let y;
        let attempts = 0;
        do {
          y = Math.floor(Math.random() * arg.grid.h);
          attempts++;
        } while (
          attempts < 50 &&
          horizontalWallPositions.some(
            (pos) => Math.abs(pos - y) < minWallSpacing
          )
        );

        if (attempts >= 50) continue;
        horizontalWallPositions.push(y);

        const startX = Math.floor(Math.random() * arg.grid.w * 0.2);
        const width = Math.floor(
          arg.grid.w * 0.4 + Math.random() * arg.grid.w * 0.4
        );

        for (let x = startX; x < Math.min(startX + width, arg.grid.w); x++) {
          const dist = Math.sqrt(
            Math.pow(x - centerX, 2) + Math.pow(y - centerY, 2)
          );
          if (dist > minClearRadius) {
            node_grid[y][x].isWall = true;
          }
        }
      }
    }

    function solveEikonalWithTimeSteps() {
      const rows = node_grid.length;
      const cols = node_grid[0].length;
      let distanceField = Array(rows)
        .fill()
        .map(() => Array(cols).fill(Infinity));
      let accepted = Array(rows)
        .fill()
        .map(() => Array(cols).fill(false));

      distanceField[target.y][target.x] = 0;
      timeSteps = [];
      timeSteps.push(JSON.parse(JSON.stringify(distanceField)));

      let heap = [{ x: target.x, y: target.y, dist: 0 }];

      function getSpeed(x, y) {
        if (x < 0 || y < 0 || x >= cols || y >= rows) return 0;
        const cell = node_grid[y][x];
        if (cell.isWall) return 0;
        return 1;
      }

      function solveEikonalUpdate(x, y) {
        if (y === target.y && x === target.x) return 0;
        const speed = getSpeed(x, y);
        if (speed === 0) return Infinity;

        let minX = Infinity;
        if (x > 0 && accepted[y][x - 1])
          minX = Math.min(minX, distanceField[y][x - 1]);
        if (x < cols - 1 && accepted[y][x + 1])
          minX = Math.min(minX, distanceField[y][x + 1]);

        let minY = Infinity;
        if (y > 0 && accepted[y - 1][x])
          minY = Math.min(minY, distanceField[y - 1][x]);
        if (y < rows - 1 && accepted[y + 1][x])
          minY = Math.min(minY, distanceField[y + 1][x]);

        if (minX > minY) [minX, minY] = [minY, minX];

        const h = 1.0;
        if (minX === Infinity) return Infinity;
        if (minY === Infinity) return minX + h / speed;

        const simpleUpdate = minX + h / speed;
        if (simpleUpdate <= minY) return simpleUpdate;

        const a = 2;
        const b = -2 * (minX + minY);
        const c = minX * minX + minY * minY - (h / speed) * (h / speed);
        const discriminant = b * b - 4 * a * c;

        if (discriminant < 0) return minX + h / speed;
        return (-b + Math.sqrt(discriminant)) / (2 * a);
      }

      function getNeighbors(x, y) {
        const neighbors = [];
        const directions = [
          [0, -1],
          [0, 1],
          [-1, 0],
          [1, 0],
        ];
        for (let [dx, dy] of directions) {
          const nx = x + dx;
          const ny = y + dy;
          if (nx >= 0 && nx < cols && ny >= 0 && ny < rows) {
            if (!node_grid[ny][nx].isWall && !accepted[ny][nx]) {
              neighbors.push({ x: nx, y: ny });
            }
          }
        }
        return neighbors;
      }

      let processedCount = 0;
      const captureInterval = Math.max(1, Math.floor((rows * cols) / 200));

      while (heap.length > 0) {
        heap.sort((a, b) => a.dist - b.dist);
        const current = heap.shift();
        if (accepted[current.y][current.x]) continue;

        accepted[current.y][current.x] = true;
        processedCount++;

        const neighbors = getNeighbors(current.x, current.y);
        for (let neighbor of neighbors) {
          const newDist = solveEikonalUpdate(neighbor.x, neighbor.y);
          if (newDist < distanceField[neighbor.y][neighbor.x]) {
            distanceField[neighbor.y][neighbor.x] = newDist;
            const existing = heap.findIndex(
              (item) => item.x === neighbor.x && item.y === neighbor.y
            );
            if (existing >= 0) {
              heap[existing].dist = newDist;
            } else {
              heap.push({ x: neighbor.x, y: neighbor.y, dist: newDist });
            }
          }
        }

        if (processedCount % captureInterval === 0) {
          timeSteps.push(JSON.parse(JSON.stringify(distanceField)));
        }
      }

      timeSteps.push(JSON.parse(JSON.stringify(distanceField)));
      maxTimeSteps = timeSteps.length;
    }

    function updateHeatmapFromTimeStep() {
      if (currentTimeStep >= timeSteps.length) {
        currentTimeStep = timeSteps.length - 1;
      }
      const distanceField = timeSteps[currentTimeStep];
      for (let y = 0; y < arg.grid.h; y++) {
        for (let x = 0; x < arg.grid.w; x++) {
          node_grid[y][x].dist = distanceField[y][x];
          node_grid[y][x].display_dist = distanceField[y][x];
        }
      }
      drawHeatmap();
    }

    function drawHeatmap() {
      gfx_heatmap.clear();
      let maxDist = 0;
      for (let y = 0; y < arg.grid.h; y++) {
        for (let x = 0; x < arg.grid.w; x++) {
          const dist = node_grid[y][x].display_dist;
          if (dist !== Infinity && !node_grid[y][x].isWall) {
            maxDist = Math.max(maxDist, dist);
          }
        }
      }

      for (let y = 0; y < arg.grid.h; y++) {
        for (let x = 0; x < arg.grid.w; x++) {
          let current_node = node_grid[y][x];
          if (current_node.dist === Infinity) continue;

          if (current_node.isWall) {
            gfx_heatmap.colorMode(p.RGB);
            gfx_heatmap.fill(47, 42, 41); // --color-bg
          } else {
            const normalizedDist =
              maxDist > 0 ? current_node.dist / maxDist : 0;
            
            if(normalizedDist > 0){

              gfx_heatmap.colorMode(p.HSB);
              const hue = 240 - normalizedDist * 240;
              gfx_heatmap.fill(hue, 100, 90);
            }
            else{
              gfx_heatmap.colorMode(p.RGBA);
              gfx_heatmap.fill(248, 248, 247, 0);

            }
          }
          gfx_heatmap.noStroke();
          gfx_heatmap.rect(
            x * arg.grid.tile_size,
            y * arg.grid.tile_size,
            arg.grid.tile_size,
            arg.grid.tile_size
          );
        }
      }

      gfx_heatmap.colorMode(p.RGB);
      gfx_heatmap.fill(255, 0, 0);
      gfx_heatmap.ellipse(
        (target.x + 0.5) * arg.grid.tile_size,
        (target.y + 0.5) * arg.grid.tile_size,
        arg.grid.tile_size * 2,
        arg.grid.tile_size * 2
      );
    }

    function handleWallDrawing() {
      const gridX = p.floor(p.mouseX / arg.grid.tile_size);
      const gridY = p.floor(p.mouseY / arg.grid.tile_size);

      if (
        gridX >= 0 &&
        gridX < arg.grid.w &&
        gridY >= 0 &&
        gridY < arg.grid.h
      ) {
        if (gridX === target.x && gridY === target.y) return;

        node_grid[gridY][gridX].isWall = wallpen_state;

        // Update heatmap visually immediate
        drawHeatmap();
      }
    }

    p.draw = () => {
      
      p.image(gfx_heatmap, 0, 0);
      // p.image(gfx_grid, 0, 0);
    };

    p.mousePressed = () => {
      if (
        p.mouseX < 0 ||
        p.mouseX > arg.screen.w ||
        p.mouseY < 0 ||
        p.mouseY > arg.screen.h
      )
        return;

      let x = p.floor(p.mouseX / arg.grid.tile_size);
      let y = p.floor(p.mouseY / arg.grid.tile_size);

      if (x >= 0 && x < arg.grid.w && y >= 0 && y < arg.grid.h) {
        wallpen_state = !node_grid[y][x].isWall;
        is_dragging = true;
        handleWallDrawing();
      }
    };

    p.mouseDragged = () => {
      if (!is_dragging) return;
      if (
        p.mouseX < 0 ||
        p.mouseX > arg.screen.w ||
        p.mouseY < 0 ||
        p.mouseY > arg.screen.h
      )
        return;
      handleWallDrawing();
    };

    p.mouseReleased = () => {
      if (is_dragging) {
        is_dragging = false;
        reSolveAndResetUI();
      }
    };
  };

  setupVisibilityPause(new p5(sketch), 'eikonalSpreadingAnim');
</script>

<style>
  .eikonal-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 20px;
    padding-bottom: 20px;
    border-radius: 12px;
    gap: 20px;
  }

  #eikonalSpreadingAnim {
    border-radius: 7px;
    overflow: hidden;
    width: 100%;
    
    height: fit-content;
    box-shadow: rgba(0, 0, 0, 0.151) 0px 0px 5px;
  }

  #eikonalSpreadingAnim canvas {
    display: block;
  }

  .controls {
    display: flex;
    flex-direction: row;
    gap: 50px;
    flex-wrap: wrap;
  }

  .single-control {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mode-selector-container,
  .button-group {
    width: fit-content;
    display: flex;
    flex-direction: row;
    outline: 2px solid #dbd8d4;
    border-radius: 8px;
    padding: 2px;
  }

  .progress-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  .slider-wrapper {
    display: flex;
    flex-direction: column;
    gap: 6px;
    outline: 2px solid #dbd8d4;
    border-radius: 8px;
    padding: 8px 12px;
  }

  input[type='range'] {
    width: 260px;
    cursor: pointer;
    accent-color: #3d3a36;
  }

  .value-display {
    font-family: "Inter", monospace;
    font-size: 11px;
    color: #615f59;
  }

  span {
    display: block;
    font-family: "Inter";
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--font-body);
  }

  button {
    font-family: "Inter";
    font-size: 13px;
    color: #615f59;
    padding: 6px 13px;
    cursor: pointer;
    transition: background 0.15s;
    border: none;
    background: none;
    border-radius: 6px;
  }

  button:hover {
    background-color: rgba(0, 0, 0, 0.06);
  }

  button.active {
    background-color: #3d3a36;
    color: #eeeadf;
  }
</style>
