---
// Vector Field Heatmap with Distance Matrix
---

<div class="djikstra-container">
  <div id="djikstraHeatmapAnim"></div>
  <div class="controls">
    <!-- <div class="controls-header">
      <p class="controls-title">Dijkstra Distance Map</p>
      <p>Each tile is colored by its distance to the cursor. Move your mouse over the canvas to update the target, or drag to draw walls.</p>
    </div> -->

    <div class="single-control">
      <span>Distance Kernel</span>
      <div class="distance-selector-container">
        <button class="dist-btn" data-distance="Euclidian">Euclidean</button>
        <button class="dist-btn" data-distance="Tchebishev">Chebyshev</button>
        <button class="dist-btn" data-distance="Manhattan">Manhattan</button>
      </div>
    </div>
    <div class="single-control">
      <span>Color Mode</span>
      <div class="mode-selector-container">
        <button class="mode-btn" data-mode="hue">Hue</button>
        <button class="mode-btn" data-mode="gradient">Magma</button>
        <button class="mode-btn" data-mode="grayscale">Gray</button>
      </div>
    </div>
    <div class="single-control">
      <span>Show Distance</span>
      <div class="show-distance-container">
        <button class="show-btn" data-show="true">On</button>
        <button class="show-btn" data-show="false">Off</button>
      </div>
    </div>
  </div>
</div>

<script>
  import { dist_arr } from '../common/constant';
import { gfx_draw_grid, gfx_draw_heatmap } from '../common/gfx_function';
import { setupVisibilityPause } from '../common/p5_utils';
import { djikstra_algorithm, node } from '../common/solver_function';
import {
  is_in_grid,
  is_in_screen,
  reset_node_grid,
} from '../common/utils_function';

  const arg = {
    screen: {
      w: 500,
      h: 450,
    },

    grid: {
      tile_size: 25,
      w: 0,
      h: 0,
      stroke: 100,
      stroke_weight: 1,
    },
  };

  var node_grid;
  var current_distance = 'Tchebishev'; // Default distance metric
  var heatmap_mode = 'hue'; // Default heatmap mode
  var show_values = false; // Default values display

  var is_dragging = false;
  var wallpen_state = true;

  var gfx_grid;
  var gfx_heatmap;

  var target = {
    x: 5,
    y: 5,
  };

  const sketch = (p) => {
    p.setup = () => {
      const container = document.getElementById('djikstraHeatmapAnim');
      arg.screen.w = container.offsetWidth;

      let canvas = p.createCanvas(arg.screen.w, arg.screen.h);
      canvas.parent('djikstraHeatmapAnim');

      arg.grid.w = p.floor(arg.screen.w / arg.grid.tile_size);
      arg.grid.h = p.floor(arg.screen.h / arg.grid.tile_size);

      node_grid = new Array(arg.grid.h)
        .fill()
        .map((_, y) =>
          new Array(arg.grid.w).fill().map((_, x) => new node(x, y))
        );

      gfx_grid = p.createGraphics(arg.screen.w, arg.screen.h);
      gfx_draw_grid(p, gfx_grid, arg);

      gfx_heatmap = p.createGraphics(arg.screen.w, arg.screen.h);
      djikstra_algorithm(node_grid, target, dist_arr[current_distance], arg);

      // Add event listener for distance buttons
      const distButtons = document.querySelectorAll('.dist-btn');

      const updateActiveButton = (activeDistance) => {
        distButtons.forEach((btn) => {
          if (btn.getAttribute('data-distance') === activeDistance) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });
      };

      // Set initial active state
      updateActiveButton(current_distance);

      distButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          current_distance = btn.getAttribute('data-distance');
          updateActiveButton(current_distance);
          reset_node_grid(node_grid);
          djikstra_algorithm(
            node_grid,
            target,
            dist_arr[current_distance],
            arg
          );
        });
      });

      // Add event listener for mode buttons
      const modeButtons = document.querySelectorAll('.mode-btn');

      const updateActiveMode = (activeMode) => {
        modeButtons.forEach((btn) => {
          if (btn.getAttribute('data-mode') === activeMode) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });
      };

      updateActiveMode(heatmap_mode);

      modeButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          heatmap_mode = btn.getAttribute('data-mode');
          updateActiveMode(heatmap_mode);
        });
      });

      // Add event listener for show distance buttons
      const showButtons = document.querySelectorAll('.show-btn');

      const updateActiveShow = (showValues: boolean) => {
        showButtons.forEach((btn) => {
          if (btn.getAttribute('data-show') === String(showValues)) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });
      };

      updateActiveShow(show_values);

      showButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          show_values = btn.getAttribute('data-show') === 'true';
          updateActiveShow(show_values);
        });
      });
    };

    p.draw = () => {
      p.clear();
      p.image(gfx_heatmap, 0, 0);
      p.image(gfx_grid, 0, 0);

      for (let y = 0; y < node_grid.length; y++) {
        for (let x = 0; x < node_grid[0].length; x++) {
          node_grid[y][x].update_display_dist(p, 0.05);

          if (show_values) {
            let current_node = node_grid[y][x];
            if (!current_node.isWall && current_node.dist !== Infinity) {
              let textColor;
              if (heatmap_mode === 'gradient') {
                let t = Math.min(current_node.display_dist / 25, 1);
                textColor = t < 0.35 ? 0 : 255;
              } else if (heatmap_mode === 'hue') {
                textColor = 0;
              } else {
                let brightness = p.map(
                  current_node.display_dist,
                  0,
                  25,
                  255,
                  0
                );
                textColor = brightness > 150 ? 0 : 255;
              }

              p.fill(textColor);
              p.noStroke();
              p.textAlign(p.CENTER, p.CENTER);
              p.textSize(10);
              p.text(
                p.round(current_node.display_dist),
                (x + 0.5) * arg.grid.tile_size,
                (y + 0.5) * arg.grid.tile_size
              );
            }
          }
        }
      }

      gfx_draw_heatmap(
        p,
        gfx_heatmap,
        node_grid,
        target,
        arg,
        heatmap_mode,
        25
      );
    };

    p.mouseMoved = () => {
      // Only respond to mouse events if mouse is over the canvas
      if (
        p.mouseX < 0 ||
        p.mouseX > arg.screen.w ||
        p.mouseY < 0 ||
        p.mouseY > arg.screen.h
      )
        return;
      if (is_in_screen(p.mouseX, p.mouseY, arg)) {
        let grid_x = p.floor(p.mouseX / arg.grid.tile_size);
        let grid_y = p.floor(p.mouseY / arg.grid.tile_size);

        target.x = grid_x;
        target.y = grid_y;
        reset_node_grid(node_grid);
        djikstra_algorithm(node_grid, target, dist_arr[current_distance], arg);
      }
    };

    p.mouseDragged = () => {
      // Only respond to mouse events if mouse is over the canvas
      if (
        p.mouseX < 0 ||
        p.mouseX > arg.screen.w ||
        p.mouseY < 0 ||
        p.mouseY > arg.screen.h
      )
        return;

      let x = p.floor(p.mouseX / arg.grid.tile_size);
      let y = p.floor(p.mouseY / arg.grid.tile_size);

      if (!is_in_grid(x, y, arg)) return;

      let current_node = node_grid[y][x];

      if (!is_dragging) {
        wallpen_state = !current_node.isWall;
        is_dragging = true;
      }

      current_node.isWall = wallpen_state;
      reset_node_grid(node_grid);
      djikstra_algorithm(node_grid, target, dist_arr[current_distance], arg);
    };

    p.mouseReleased = () => {
      if (is_dragging) is_dragging = false;
    };
  };

  setupVisibilityPause(new p5(sketch), 'djikstraHeatmapAnim');
</script>

<style>
  .djikstra-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    /* background-color: var(--color-secondary); */
    padding: 0 20px;
    padding-bottom: 20px;
    /* padding-bottom: 30px; */
    border-radius: 12px;
    gap: 20px;
    /* border: 1.2px solid #e5e0d4; */
  }

  .djikstra-title{
    font-family: "Inter";
    font-size: 30px;
    font-weight: 700;
  }

  #djikstraHeatmapAnim {
    overflow: hidden;
    border-radius: 8px;
    width: 100%;
    height: fit-content;
    box-shadow: rgba(0, 0, 0, 0.151) 0px 0px 5px;
    /* border: 2px solid #e5e0d4; */
  }

  #djikstraHeatmapAnim canvas {
    display: block;
  }

  .controls {
    display: flex;
    flex-direction: row;
    gap: 50px;

  }

  .controls-header {
    background-color: #e4e4d9;
    border-radius: 8px;
    padding: 14px 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .controls-title {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    color: #3d3a36;
    letter-spacing: 0.01em;
    margin: 0;
  }

  .single-control {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .distance-selector-container,
  .mode-selector-container,
  .show-distance-container {
    width: fit-content;
    display: flex;
    flex-direction: row;
    /* background-color: #eaeaea; */
    outline: 2px solid #dbd8d4;
    border-radius: 8px;
    padding: 2px;
  }

  span {
    display: block;
        font-family: "Inter";
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--font-body);
  }

  p {
    margin: 0;
    font-size: 13px;
    line-height: 1.6;
    color: #615f59;
  }

  button {
            font-family: "Inter";

    font-size: 13px;
    color: #615f59;
    padding: 6px 13px;
    cursor: pointer;
    transition: background 0.15s;
    border: none;
    background: none;
    border-radius: 6px;
  }

  button:hover {
    background-color: rgba(0, 0, 0, 0.06);
  }

  button.active {
    background-color: #3d3a36;
    color: #eeeadf;
  }
</style>
