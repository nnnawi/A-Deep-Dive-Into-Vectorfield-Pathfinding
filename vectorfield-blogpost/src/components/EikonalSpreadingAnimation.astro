---
// Eikonal Spreading Animation
const { title = 'Eikonal Spreading Animation' } = Astro.props;
---

<div class="p5-component">
  <div id="eikonal_spreading_animation_canva"></div>
</div>

<script>
  import eikonal_spreading_animation_sketch from '../../../scripts/eikonal_spreading_animation.js';

  // Initialize p5 instance with the sketch
  const initEikonalSpreadingAnimation = () => {
    if (typeof window !== 'undefined' && window.p5) {
      new p5((p) =>
        eikonal_spreading_animation_sketch(
          p,
          'eikonal_spreading_animation_canva'
        )
      );
    }
  };

  // Wait for p5 to be loaded
  if (document.readyState === 'loading') {
    document.addEventListener(
      'DOMContentLoaded',
      initEikonalSpreadingAnimation
    );
  } else {
    initEikonalSpreadingAnimation();
  }
</script>

<style>
  .p5-component {
    margin: 2rem 0;
    display: flex;
    justify-content: center;
  }

  #eikonal_spreading_animation_canva {
    border: 2px solid #dee2e6;
    border-radius: 4px;
    overflow: hidden;
    background: white;
  }
</style>
