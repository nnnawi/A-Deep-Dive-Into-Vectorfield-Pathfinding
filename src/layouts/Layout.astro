---
// Base layout component
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vector Field Pathfinding</title>

    <!-- Google Fonts - Custom font for text -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&display=swap" rel="stylesheet">
    <!-- p5.js library -->
    <script src="https://cdn.jsdelivr.net/npm/p5@1.9.0/lib/p5.min.js"></script>

    <style is:global>
      :root {
        --color-primary: #007acc;
        --color-text: #2f2a29;
        --color-text-light: #5a6c7d;
        --color-bg: #f8f8f7;
        --color-yellow: #F6DE1E;
        --color-blue: #3D54BC;
        --color-red: #DC1D0A;
        --color-secondary: #f1f1f0;
        --font-body: 'Merriweather', serif;
        --font-heading: "Playfair Display", serif;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: var(--font-body);
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem;
        background: var(--color-bg);
        color: var(--color-text);
        
      }

      .container {
        padding: 3rem;
        border-radius: 12px;
        /* box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); */
      }

      .latex-animation-container {
        display: flex;
        flex-direction: row;
        align-items: center;
        width: fit-content;
        margin: 0 auto 45px auto;

        gap: 40px;
      }

      .pseudo-code-container{
        width: 100%;
        overflow-x: auto;
        display: flex;
        flex-direction: column;
        background-color: #e6edf9;
        color: #18306a;
        padding: 0 25px 15px 25px;
        border-radius: 7px;
        font-size: 15px;

        .title {
          font-family: "Inter";
          font-weight: 700;
          letter-spacing: .9px;
          font-size: 13px;
          text-transform: uppercase;
          padding: 18px 0 4px 0;
        }

        /* mjx-container[display='true'] {
          text-align: left;
          margin: 0.5rem 0;
        } */
      }

      .ytb-video-container{
        display: flex;
        justify-content: center;
        padding: 25px 0;
        position: relative;

        img {
          top: -26px;
          position: absolute;
          width: 665px;
          height: 415px;
        }
      }

      .info-container{
        display: flex;
        flex-direction: column;
        gap: 6px;
        background-color: #f8ecd4;
        color: #493510;
        border-radius: 7px;
        padding: 20px 25px;

        p{
          font-size: 16px;
          line-height: 26px;
          padding-left: 6px;
          margin: 0;
        }

        .title{
          font-family: "Inter";
          font-weight: 700;
          letter-spacing: .9px;
          font-size: 13px;
          text-transform: uppercase;
        }
      }

      .expandable-container {
        display: flex;
        flex-direction: column;
        background-color: #e6edf9;
        color: #18306a;
        border-radius: 7px;
        overflow: hidden;

        > .title {
          font-family: "Inter";
          font-weight: 700;
          letter-spacing: .9px;
          font-size: 13px;
          text-transform: uppercase;
          padding: 18px 25px 4px 25px;
        }
      }

      .expandable-content {
        padding: 0 25px;
        max-height: 100px;
        overflow: hidden;
        transition: max-height 0.45s cubic-bezier(0.4, 0, 0.2, 1);

        p {
          font-size: 16px;
          line-height: 26px;
          padding-left: 6px;
          margin: 10px 0;
          color: #18306a;
        }

        ul {
          padding-left: 2.5rem;
          font-size: 16px;
          line-height: 26px;
          margin: 6px 0;
          color: #18306a;
        }

        li {
          margin: 4px 0;
        }

        mjx-container[display='true'] {
          margin: 1rem 0;
        }
      }

      .expandable-fade {
        height: 64px;
        background: linear-gradient(to bottom, transparent, #e6edf9);
        margin-top: -64px;
        pointer-events: none;
        flex-shrink: 0;
        transition: opacity 0.3s ease;

        &.hidden {
          opacity: 0;
        }
      }

      .expandable-toggle {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: none;
        border: none;
        cursor: pointer;
        font-family: "Inter";
        font-size: 12px;
        font-weight: 700;
        color: #3D54BC;
        text-transform: uppercase;
        letter-spacing: .9px;
        padding: 10px 25px 18px 25px;
        align-self: flex-start;
        transition: color 0.2s;

        &:hover {
          color: #2a3c90;

          .expandable-toggle-text {
            border-bottom-color: #2a3c90;
          }
        }
      }

      .expandable-toggle-text {
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s;
      }

      .expandable-toggle-icon {
        font-size: 10px;
        transition: transform 0.35s ease;
        display: inline-block;
      }

      .complexity-table-wrapper {
        margin: 1.5rem 0 2rem 0;
        border-radius: 7px;
        overflow: hidden;
        border: 1px solid #e0c48a;
        font-family: "Inter";

        table {
          width: 100%;
          border-collapse: collapse;
          margin: 0;
        }

        th {
          background-color: #f8ecd4;
          color: #493510;
          font-weight: 600;
          padding: 10px 18px;
          text-align: left;
          border-bottom: 2px solid #e0c48a;
          font-size: 13px;
          letter-spacing: 0.3px;
          white-space: nowrap;
        }

        td {
          padding: 11px 18px;
          border-bottom: 1px solid #f0dfc0;
          color: var(--color-text);
          font-family: var(--font-body);
          line-height: 1.5;
          vertical-align: middle;
          font-size: 13px;
          background-color: #f8ecd4;
        }

        tr:last-child td {
          border-bottom: none;
        }
      }


      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-family: var(--font-heading);
        font-weight: 700;
        color: var(--color-text);
      }

      h1 {
        font-size: 63px;
        line-height: 1.2;
        margin-bottom: 70px;
      }

      h2 {
        font-family: "Inter";
        font-size: 48px;
        font-weight: 700;
        line-height: 1.3;
        width: fit-content;
        /* padding: 0 5px;  */
        /* padding-bottom: 3px; */
        /* padding-right: 20px; */
        /* border-bottom: 8px solid var(--color-blue); */
      }

      h3 {
        font-family: "Inter";
        font-size: 30px;
      }

      h4 {
        font-family: "Inter";
        font-size: 20px;
        font-weight: 500;
        padding-top: 7px;
      }

      p {
        margin: 23px 0;
        line-height: 31px;
        font-size: 18px;
        
      }

      .title-indication{
        font-size: 14px; 
        color: #837a7a;
      }

      /* Code and inline code */
      code {
        font-family: 'Fira Code', 'Courier New', monospace;
        background: #f4f4f4;
        padding: 0.2rem 0.4rem;
        border-radius: 3px;
        font-size: 0.9em;
      }

      pre code {
        display: block;
        padding: 1rem;
        overflow-x: auto;
        background: #282c34;
        color: #abb2bf;
        border-radius: 6px;
      }

      /* Math styling */
      mjx-container {
        margin: 1rem 0;
      }

      mjx-container[display='true'] {
        display: block;
        margin: 2rem 0;
      }

      /* Links */
      a {
        color: var(--color-primary);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s;
      }

      a:hover {
        border-bottom-color: var(--color-primary);
      }

      /* Lists */
      ul,
      ol {
        margin: 1rem 0;
        padding-left: 2rem;
      }

      li {
        margin: 0.5rem 0;
      }

      /* Blockquotes */
      blockquote {
        margin: 2rem 0;
        padding: 1rem 1.5rem;
        border-left: 4px solid var(--color-primary);
        background: #f9f9f9;
        font-style: italic;
        color: var(--color-text-light);
      }

      /* Responsive */
      @media (max-width: 768px) {
        body {
          padding: 1rem;
          font-size: 16px;
        }

        .container {
          padding: 1.5rem;
        }

        h1 {
          font-size: 2rem;
        }

        h2 {
          font-size: 1.5rem;
        }
      }

      .header {
        position: absolute;
        top: 2rem;
        left: 2rem;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 0.75rem;
        z-index: 100;
      }

      .header-top {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .author-name {
        font-family: var(--font-body);
        font-size: 0.85rem;
        color: var(--color-text-light);
        font-weight: 400;
        letter-spacing: 0.3px;
        text-decoration: none;
        transition: color 0.3s ease;
        cursor: pointer;
      }

      .author-name:hover {
        color: var(--color-blue);
      }
    </style>
  </head>
  <body>
    <header class="header">
      <div class="header-top">
        <a href="https://github.com/nnnawi" class="author-name" target="_blank" rel="noopener noreferrer">Made by Iwan Ibnoulouafi</a>
      </div>
    </header>
    <div class="container">
      <slot />
    </div>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.expandable-container').forEach(function(container) {
          var content = container.querySelector('.expandable-content');
          var fade = container.querySelector('.expandable-fade');
          var toggle = container.querySelector('.expandable-toggle');
          if (!content || !fade || !toggle) return;

          var toggleText = toggle.querySelector('.expandable-toggle-text');
          var toggleIcon = toggle.querySelector('.expandable-toggle-icon');
          var expanded = false;

          toggle.addEventListener('click', function() {
            expanded = !expanded;
            if (expanded) {
              content.style.maxHeight = content.scrollHeight + 'px';
              fade.classList.add('hidden');
              if (toggleText) toggleText.textContent = 'Show less';
              if (toggleIcon) toggleIcon.style.transform = 'rotate(180deg)';
            } else {
              content.style.maxHeight = '100px';
              fade.classList.remove('hidden');
              if (toggleText) toggleText.textContent = 'Full explanation';
              if (toggleIcon) toggleIcon.style.transform = '';
            }
          });
        });
      });
    </script>
  </body>
</html>
